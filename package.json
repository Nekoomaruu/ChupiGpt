{
  "name": "chupigpt",
  "version": "2.0.0",
  "description": "The world's most focused AI suite. Two models: ChupiGpt 2.0 ('Phoebe chupi') and GugugagaGpt 2 ('Gugu gaga'). 100% local, zero API, zero cost.",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "chupigpt": "bin/chupigpt.js"
  },
  "scripts": {
    "start": "node bin/chupigpt.js",
    "cli": "node bin/chupigpt.js",
    "chupi": "node bin/chupigpt.js --model=chupi",
    "gugugaga": "node bin/chupigpt.js --model=gugugaga",
    "serve": "node src/server.js",
    "test": "node src/core.test.js"
  },
  "keywords": ["chupi", "gugugaga", "phoebe", "ai", "parody", "meme", "wuthering-waves", "cli", "chatbot"],
  "author": "OpenNekoAi",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "express": "^4.19.2"
  }
}
